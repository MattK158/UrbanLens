cat > .gitignore << 'EOF'
# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
*.egg-info/
dist/
build/

# Environment variables - NEVER commit these
.env
backend/.env
frontend/.env

# PostgreSQL
*.sql.bak

# Node
node_modules/
frontend/build/
npm-debug.log*

# VSCode
.vscode/

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/
